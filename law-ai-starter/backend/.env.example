APP_NAME=Law AI Backend
APP_VERSION=0.1.0
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_PUBLIC_BASE_URL=http://localhost:8000
APP_LOG_LEVEL=INFO
APP_LOG_JSON=false
APP_REQUEST_LOGGING_ENABLED=true
APP_READINESS_REQUIRES_DATABASE=false
APP_READINESS_REQUIRES_OPENAI=false
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
OPENAI_API_KEY=
DATABASE_URL=
DATABASE_ECHO=false
DATABASE_POOL_PRE_PING=true
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_CONNECT_TIMEOUT_SECONDS=5
DATABASE_AUTO_CREATE_TABLES=false
DATABASE_BOOTSTRAP_LEGAL_SOURCES=false
DATABASE_BOOTSTRAP_FORCE_REFRESH=false
LEGAL_SOURCE_EMBEDDING_DIMENSIONS=1536
REDIS_URL=
LEGAL_SOURCE_EMBEDDING_MODEL=text-embedding-3-small
LEGAL_SOURCE_VECTOR_SEARCH_ENABLED=false
LEGAL_SOURCE_VECTOR_QUERY_TOP_K=8
ADMIN_AUTH_SECRET_KEY=change-this-law-ai-admin-secret
ADMIN_AUTH_USERNAME=admin
ADMIN_AUTH_PASSWORD=admin123
ADMIN_AUTH_WRITE_ROLES=["admin"]
